{
  "name": "nexus-boost",
  "version": "1.0.0",
  "description": "Fortnite Performance Control Center",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.nexusboost.app",
    "productName": "Nexus Boost",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "core/**/*",
      "scripts/**/*",
      "config/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "deb",
      "category": "Game"
    }
  }
}
